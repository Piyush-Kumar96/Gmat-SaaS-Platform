# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/gmat-quiz

# JWT Secrets for Authentication
JWT_SECRET=replace_with_long_random_string
JWT_REFRESH_SECRET=replace_with_another_long_random_string
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# OpenAI API (optional - only required for AI answer/explanation generation scripts)
OPENAI_API_KEY=

# Server
PORT=5006

# Razorpay (optional - only required if exercising the payments flow)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
