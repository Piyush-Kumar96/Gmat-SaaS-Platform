{
  "name": "gmat-quiz-backend",
  "version": "1.0.0",
  "description": "Backend for GMAT Quiz Platform",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "NODE_OPTIONS=--max-old-space-size=2048 ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "lint": "eslint 'src/**/*.ts' --ignore-pattern 'src/scripts/**'",
    "lint:fix": "eslint 'src/**/*.ts' --fix --ignore-pattern 'src/scripts/**'",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "create-test-user": "ts-node src/scripts/createTestUser.ts",
    "create-sample-questions": "ts-node src/scripts/createSampleQuestions.ts",
    "create-sample-quiz": "ts-node src/scripts/createSampleQuiz.ts",
    "add-critical-reasoning": "ts-node src/scripts/addCriticalReasoningQuestion.ts",
    "rc-migration-report": "ts-node src/scripts/rcMigrationReport.ts",
    "backfill-formatting": "ts-node src/scripts/backfillFormattedText.ts"
  },
  "keywords": [
    "gmat",
    "quiz",
    "education"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/exceljs": "^0.5.3",
    "axios": "^1.9.0",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.0.3",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-fileupload": "^1.5.1",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.0.0",
    "openai": "^5.1.0",
    "p-limit": "^3.1.0",
    "pdf-parse": "^1.1.1",
    "puppeteer": "^24.7.2",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "razorpay": "^2.9.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/express-fileupload": "^1.5.1",
    "@types/jsonwebtoken": "^9.0.1",
    "@types/node": "^18.15.0",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "eslint": "^9.39.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^4.9.5"
  }
}
